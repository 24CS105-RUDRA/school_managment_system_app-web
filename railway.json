{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd api && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd api && node dist/index.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "always"
  }
}
